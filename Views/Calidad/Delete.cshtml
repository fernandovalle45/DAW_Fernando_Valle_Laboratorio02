@model SistemaControlDeCalidad.Models.InspeccionCalidad

@{
    ViewData["Title"] = "Eliminar Inspección";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h1 class="display-6">Eliminar Inspección</h1>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h5><i class="bi bi-exclamation-triangle"></i> ¿Está seguro de eliminar esta inspección?</h5>
                        <p>Esta acción no se puede deshacer.</p>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.NumeroInspeccion)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.NumeroInspeccion)</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Lote)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Lote)</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Producto)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Producto)</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Inspector)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Inspector)</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.CantidadInspeccionada)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.CantidadInspeccionada)</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.CantidadDefectuosa)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.CantidadDefectuosa)</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.PorcentajeDefectos)</dt>
                        <dd class="col-sm-8">@Model.PorcentajeDefectos.ToString("F2")%</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Resultado)</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.Resultado == "Aprobado" ? "bg-success" : "bg-danger")">
                                @Html.DisplayFor(model => model.Resultado)
                            </span>
                        </dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.NivelCalidad)</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.NivelCalidad == "Excelente" ? "bg-success" :
                                                                                   Model.NivelCalidad == "Bueno" ? "bg-info" :
                                                                                   Model.NivelCalidad == "Regular" ? "bg-warning" : "bg-danger")">
                                @Html.DisplayFor(model => model.NivelCalidad)
                            </span>
                        </dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.FechaInspeccion)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.FechaInspeccion)</dd>

                        @if (!string.IsNullOrEmpty(Model.TipoDefecto))
                        {
                            <dt class="col-sm-4">@Html.DisplayNameFor(model => model.TipoDefecto)</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.TipoDefecto)</dd>
                        }
                    </dl>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="mt-3">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Eliminar
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Volver
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}