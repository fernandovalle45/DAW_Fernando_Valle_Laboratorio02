@model List<SistemaControlDeCalidad.Models.InspeccionCalidad>

@{
    ViewData["Title"] = "Control de Calidad";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-4">Control de Calidad</h1>
            <p class="lead">Gestión de inspecciones de producción</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-circle"></i> Nueva Inspección
            </a>
            <a asp-action="Dashboard" class="btn btn-info btn-lg">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
        </div>
    </div>

    <!-- Búsqueda y Filtrado -->
    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="Search" method="get" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="termino" class="form-control" placeholder="Buscar por número, lote, producto..." />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Buscar</button>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-secondary w-100">Limpiar</a>
                </div>
            </form>

            <form asp-action="Filter" method="get" class="row g-3 mt-3">
                <div class="col-md-3">
                    <select name="producto" class="form-select" asp-items="ViewBag.Productos">
                        <option value="">Todos los productos</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="resultado" class="form-select">
                        <option value="">Todos los resultados</option>
                        <option value="Aprobado">Aprobado</option>
                        <option value="Rechazado">Rechazado</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Mensajes de éxito/error -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Tabla de inspecciones -->
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(m => m.FirstOrDefault().NumeroInspeccion)</th>
                    <th>Lote</th>
                    <th>Producto</th>
                    <th>Inspector</th>
                    <th>Cantidad</th>
                    <th>Defectuosas</th>
                    <th>% Defectos</th>
                    <th>Resultado</th>
                    <th>Nivel</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.NumeroInspeccion</td>
                        <td>@item.Lote</td>
                        <td>@item.Producto</td>
                        <td>@item.Inspector</td>
                        <td>@item.CantidadInspeccionada</td>
                        <td>@item.CantidadDefectuosa</td>
                        <td>@item.PorcentajeDefectos.ToString("F2")%</td>
                        <td>
                            <span class="badge @(item.Resultado == "Aprobado" ? "bg-success" : "bg-danger")">
                                @item.Resultado
                            </span>
                        </td>
                        <td>
                            <span class="badge @(item.NivelCalidad == "Excelente" ? "bg-success" :
                                                                                   item.NivelCalidad == "Bueno" ? "bg-info" :
                                                                                   item.NivelCalidad == "Regular" ? "bg-warning" : "bg-danger")">
                            @item.NivelCalidad
                        </span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                            <i class="bi bi-eye">Detalles</i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil">Editar</i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash">Eliminar</i>
                        </a>
                    </td>
                </tr>
                                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <p>No hay inspecciones registradas.</p>
        </div>
    }
</div>